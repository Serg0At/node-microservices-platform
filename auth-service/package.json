{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/app.js",
    "start": "NODE_ENV=production node src/app.js",
    "debug": "NODE_OPTIONS='--inspect' nodemon src/app.js",
    "reload": "npx kill-port 50051 && npm run dev",
    "migrate": "node ./migrations/create_tables.js",
    "migrate-down": "node ./migrations/drop_tables.js",
    "seed": "node ./seed/seed.js",
    "proto:check": "find ./proto -name '*.proto' -print",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "docker:build": "docker build -t auth-service .",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down",
    "asyncapi:docs": "asyncapi generate fromTemplate asyncapi.yaml @asyncapi/html-template -o docs/asyncapi",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --verbose",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.2",
    "@grpc/proto-loader": "^0.8.0",
    "amqplib": "^0.10.9",
    "bcryptjs": "^3.0.3",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "knex": "^3.1.0",
    "opossum": "^9.0.0",
    "otplib": "^12.0.1",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@jest/globals": "^30.2.0",
    "@nx/docker": "22.3.3",
    "@nx/eslint": "22.3.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "nx": "22.3.3",
    "prettier": "^3.7.4"
  },
  "author": "Serg",
  "license": "ISC"
}
