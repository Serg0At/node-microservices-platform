{
  "name": "news-service",
  "version": "1.0.0",
  "description": "",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/app.js",
    "start": "NODE_ENV=production node src/app.js",
    "debug": "NODE_OPTIONS='--inspect' nodemon src/app.js",
    "reload": "npx kill-port 50054 && npm run dev",
    "migrate": "node ./migrations/create_tables.js",
    "migrate-down": "node ./migrations/drop_tables.js",
    "proto:check": "find ./proto -name '*.proto' -print",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "asyncapi:docs": "asyncapi generate fromTemplate docs/asyncapi.yml @asyncapi/html-template -o docs/api-docs",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --verbose",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.800.0",
    "@grpc/grpc-js": "^1.14.2",
    "@grpc/proto-loader": "^0.8.0",
    "amqplib": "^0.10.9",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "opossum": "^9.0.0",
    "pg": "^8.16.3",
    "slugify": "^1.6.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@jest/globals": "^30.2.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.7.4"
  },
  "author": "Serg",
  "license": "ISC"
}
