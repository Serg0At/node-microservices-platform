# Server
SERVICE_NAME=news-service
SERVICE_ENV=development
SERVICE_PORT=50054
SERVICE_LOG_LEVEL=info

# PostgreSQL (same instance as auth-service)
PSQL_HOST=localhost
PSQL_PORT=5432
PSQL_USER=
PSQL_PASSWORD=
PSQL_DATABASE=
PSQL_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_ARTICLE_CACHE_TTL=900
REDIS_LATEST_LIST_TTL=300
REDIS_POPULAR_CATEGORY_TTL=1800
REDIS_SEARCH_CACHE_TTL=300

# RabbitMQ
RABBIT_URL=amqp://admin:admin@localhost:5672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RMQ_EXCHANGE=news-events
RMQ_EXCHANGE_TYPE=topic

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=news-media-bucket
S3_PRESIGNED_EXPIRES=3600
S3_FORCE_PATH_STYLE=true

# JWT (public key only — verify tokens signed by auth-service)
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/access_public.pem
JWT_ACCESS_ALG=RS256
JWT_ISSUER=auth-service
JWT_AUDIENCE=graphql-gateway

# gRPC
GRPC_MAX_MESSAGE_SIZE=4194304
INTERNAL_GRPC_SHARED_SECRET=
TRUSTED_GATEWAY_SERVICE=graphql-gateway
