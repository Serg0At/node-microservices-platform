# Server
SERVICE_NAME=admin-service
SERVICE_ENV=development
SERVICE_PORT=50055
SERVICE_LOG_LEVEL=info

# PostgreSQL (same DB as auth-service — reads users table)
PSQL_HOST=localhost
PSQL_PORT=5432
PSQL_USER=postgres
PSQL_PASSWORD=postgres
PSQL_DATABASE=arbex_auth
PSQL_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# JWT (public key only — verify tokens, not issue)
JWT_ACCESS_ALG=RS256
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/access_public.pem

# gRPC backends
NEWS_SERVICE_URL=localhost:50054
NOTIFICATION_SERVICE_URL=localhost:50053
