# Server
SERVICE_NAME=subscription-service
SERVICE_ENV=development
SERVICE_PORT=50056
SERVICE_LOG_LEVEL=info

# PostgreSQL
PSQL_HOST=localhost
PSQL_PORT=5432
PSQL_USER=
PSQL_PASSWORD=
PSQL_DATABASE=
PSQL_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBIT_URL=amqp://localhost
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# RabbitMQ Exchanges & Queues
RMQ_AUTH_EXCHANGE=auth-events
RMQ_PAYMENT_EXCHANGE=payment-events
RMQ_PUBLISH_EXCHANGE=subscription-events
RMQ_EXCHANGE_TYPE=topic

RMQ_AUTH_QUEUE=subscription-service.auth.queue
RMQ_AUTH_BIND_PATTERN=user.registered

RMQ_PAYMENT_QUEUE=subscription-service.payment.queue
RMQ_PAYMENT_BIND_PATTERN=payment.*

RMQ_PREFETCH=10
RMQ_MAX_RETRIES=3
RMQ_RETRY_DELAY=5000
RMQ_RECONNECT_INTERVAL=3000

# Payment Service gRPC
PAYMENT_SERVICE_HOST=localhost
PAYMENT_SERVICE_PORT=50055
PAYMENT_PROTO_PATH=

# Plan Pricing (cents)
PLAN_LITE_PRICE_1M=999
PLAN_LITE_PRICE_3M=2697
PLAN_LITE_PRICE_6M=4794
PLAN_LITE_PRICE_12M=8388

PLAN_STANDARD_PRICE_1M=1999
PLAN_STANDARD_PRICE_3M=5397
PLAN_STANDARD_PRICE_6M=9594
PLAN_STANDARD_PRICE_12M=16790

PLAN_PRO_PRICE_1M=3999
PLAN_PRO_PRICE_3M=10797
PLAN_PRO_PRICE_6M=19194
PLAN_PRO_PRICE_12M=33590

PLAN_CURRENCY=USD

PLAN_DISCOUNT_3M=10
PLAN_DISCOUNT_6M=20
PLAN_DISCOUNT_12M=30

# Expiry Worker
EXPIRY_INTERVAL_MS=3600000
GRACE_PERIOD_DAYS=3

# gRPC
GRPC_MAX_MESSAGE_SIZE=4194304
