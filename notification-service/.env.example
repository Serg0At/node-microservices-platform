# Server
SERVICE_NAME=notification-service
SERVICE_ENV=development
SERVICE_PORT=50053
SERVICE_LOG_LEVEL=info

# PostgreSQL (same instance as auth-service)
PSQL_HOST=localhost
PSQL_PORT=5432
PSQL_USER=
PSQL_PASSWORD=
PSQL_DATABASE=
PSQL_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBIT_URL=amqp://localhost
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# RabbitMQ Exchange (must match auth-service)
RMQ_EXCHANGE=auth-events
RMQ_EXCHANGE_TYPE=topic
RMQ_QUEUE=notification-service.events.queue
RMQ_BIND_PATTERN=user.*
RMQ_PREFETCH=10
RMQ_MAX_RETRIES=3
RMQ_RETRY_DELAY=5000
RMQ_RECONNECT_INTERVAL=3000

# SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Arbex
SMTP_FROM_EMAIL=

# Notification Settings
NOTIFICATION_ARCHIVE_DAYS=90
NOTIFICATION_ARCHIVE_INTERVAL_MS=86400000
NOTIFICATION_MAX_RETRIES=3

# gRPC
GRPC_MAX_MESSAGE_SIZE=4194304
