# --- Environment ---
NODE_ENV=development

# --- Server ---
SERVICE_NAME=user-service
SERVICE_ENV=development
SERVICE_PORT=50052
SERVICE_LOG_LEVEL=debug

# --- PostgreSQL (same instance as auth-service) ---
PSQL_HOST=
PSQL_PORT=5432
PSQL_USER=
PSQL_PASSWORD=
PSQL_DATABASE=
PSQL_SSL=true

# --- Redis (for caching profile lookups) ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBIT_URL=amqp://admin:admin@localhost:5672

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=arbex-assets

# --- JWT (public key only — verify access tokens, never sign) ---
JWT_ACCESS_PUBLIC_KEY_PATH=./keys/access_public.pem
JWT_ACCESS_ALG=RS256

# --- gRPC ---
GRPC_MAX_MESSAGE_SIZE=4194304
